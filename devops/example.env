# Example environment file for local development and local production testing.
# Copy it to the project root as '.env' and adjust the values.

# Private key used to encrypt/decrypt secrets. Change it in production.
API_SECRET=dev-secret-key-change-in-production

# PostgreSQL connection.
# DB_HOST is 'db' inside Docker Compose; dev.sh overrides it to 'localhost'
# automatically because the API runs on the host.
DB_HOST=db
DB_PORT=5432
DB_NAME=secretly
DB_USER=secretly
DB_PASS=secretly_dev_password

# Hibernate schema mode: 'update' keeps data, 'create-drop' recreates the schema.
DB_DLL_MODE=update

# Spring logging level: DEBUG, INFO, TRACE...
LOGGING_LEVEL=DEBUG

# Host of the frontend allowed by CORS (no protocol, no port).
CORS_HOST=localhost
