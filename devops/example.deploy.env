# Example environment file for the VPS deployment (Traefik + HTTPS).
# Copy it next to docker-compose.traefik.yml on the VPS as '.env'.

# Image version published on DockerHub (e.g. v1.0.3 or latest).
VERSION=latest

# Public hostnames routed by Traefik. Create an A record for each one
# pointing to the VPS IP before deploying.
FRONTEND_HOST=secretly.example.com
API_HOST=api.secretly.example.com

# Private key used to encrypt/decrypt secrets. Use a long random value.
API_SECRET=change-me-to-a-long-random-secret

# PostgreSQL connection (external database by default).
# If you enable the bundled 'db' service in the compose file, set DB_HOST=db.
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=secretly
DB_USER=secretly
DB_PASS=change-me

# Hibernate schema mode: 'update' for a persistent database.
DB_DLL_MODE=update

# Spring logging level for production.
LOGGING_LEVEL=INFO
